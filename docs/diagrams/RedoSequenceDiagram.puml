@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":CommandHistory" as CommandHistory LOGIC_COLOR
participant "r:RedoCommand" as RedoCommand LOGIC_COLOR
participant "d:DeleteCommand" as DeleteCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("redo")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("redo")
activate AddressBookParser

create RedoCommand
AddressBookParser -> RedoCommand
activate RedoCommand

RedoCommand --> AddressBookParser
deactivate RedoCommand

AddressBookParser --> LogicManager : r
deactivate AddressBookParser

LogicManager -> RedoCommand : execute(m)
activate RedoCommand

RedoCommand -> CommandHistory : canRedo()
activate CommandHistory
CommandHistory --> RedoCommand : true
deactivate CommandHistory

RedoCommand -> CommandHistory : popRedo()
activate CommandHistory
CommandHistory --> RedoCommand : d
deactivate CommandHistory

RedoCommand -> DeleteCommand : redo(m)
activate DeleteCommand

DeleteCommand -> Model : deletePerson(deletedPerson)
activate Model
Model --> DeleteCommand
deactivate Model

DeleteCommand --> RedoCommand
deactivate DeleteCommand

RedoCommand -> CommandHistory : pushToUndo(d)
activate CommandHistory
CommandHistory --> RedoCommand
deactivate CommandHistory

RedoCommand -> Model : updateFilteredPersonList(PREDICATE_SHOW_ALL_PERSONS)
activate Model
Model --> RedoCommand
deactivate Model

RedoCommand --> LogicManager : result
deactivate RedoCommand
RedoCommand -[hidden]-> LogicManager
destroy RedoCommand

[<-- LogicManager
deactivate LogicManager
@enduml
