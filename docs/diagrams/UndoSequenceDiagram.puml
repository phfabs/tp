@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":CommandHistory" as CommandHistory LOGIC_COLOR
participant "u:UndoCommand" as UndoCommand LOGIC_COLOR
participant "d:DeleteCommand" as DeleteCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("undo")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("undo")
activate AddressBookParser

create UndoCommand
AddressBookParser -> UndoCommand
activate UndoCommand

UndoCommand --> AddressBookParser
deactivate UndoCommand

AddressBookParser --> LogicManager : u
deactivate AddressBookParser

LogicManager -> UndoCommand : execute(m)
activate UndoCommand

UndoCommand -> CommandHistory : peek()
activate CommandHistory
CommandHistory --> UndoCommand : d
deactivate CommandHistory

UndoCommand -> DeleteCommand : undo(m)
activate DeleteCommand

DeleteCommand -> Model : setAddressBook(previousAddressBook)
activate Model
Model --> DeleteCommand
deactivate Model

DeleteCommand --> UndoCommand
deactivate DeleteCommand

UndoCommand -> CommandHistory : pop()
activate CommandHistory
CommandHistory --> UndoCommand : d
deactivate CommandHistory

UndoCommand -> CommandHistory : pushRedo(d)
activate CommandHistory
CommandHistory --> UndoCommand
deactivate CommandHistory

UndoCommand -> Model : updateFilteredPersonList(PREDICATE_SHOW_ALL_PERSONS)
activate Model
Model --> UndoCommand
deactivate Model

UndoCommand --> LogicManager : result
deactivate UndoCommand
UndoCommand -[hidden]-> LogicManager
destroy UndoCommand

[<-- LogicManager
deactivate LogicManager
@enduml
